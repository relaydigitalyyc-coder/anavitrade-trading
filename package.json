{
  "name": "anavitrade-trading",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "wrangler dev --env dev --port 8787",
    "build": "vite build",
    "check": "tsc --noEmit && tsc --noEmit -p src/server/tsconfig.json",
    "preview": "vite preview --host 0.0.0.0",
    "smoke:wallet": "node tests/smoke-wallet.mjs",
    "test:wallet": "node tests/wallet-e2e.mjs",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run",
    "db:migrate": "wrangler d1 execute anavitrade-db --file=./migrations/001_init.sql"
  },
  "dependencies": {
