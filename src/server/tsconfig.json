{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@/*": ["../*"],
      "@shared/*": ["../../shared/*"]
    },
    "baseUrl": "."
  },
  "include": ["./**/*.ts", "../../shared/**/*.ts"]
}
